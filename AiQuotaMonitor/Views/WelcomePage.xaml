<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel MaxWidth="720" Padding="40,28" Spacing="26" HorizontalAlignment="Center">

            <!-- Hero -->
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="📊" FontSize="44" HorizontalAlignment="Center"/>
                <TextBlock Text="欢迎使用 AI Quota Monitor" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="添加你的第一个账号，开始监控 AI 服务用量。支持智谱 GLM、小米 MiMo 与自定义提供商。"
                           FontSize="13" Foreground="{ThemeResource SubtleTextBrush}"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="540"/>
            </StackPanel>

            <!-- 直接跳转设置页配置账号 -->
            <Button Click="GoSetup_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,14" HorizontalAlignment="Center" MinWidth="280">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="➕ 添加账号" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="选择提供商 → 填写凭据 → 开始监控" FontSize="11" Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 提供商预览 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="16" MinHeight="100">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#0EA5E9">
                            <TextBlock Text="G" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="智谱 GLM" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="API Key 鉴权" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16" MinHeight="100">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#FF6900">
                            <TextBlock Text="M" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="小米 MiMo" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cookie 鉴权" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16" MinHeight="100">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#6B7280">
                            <TextBlock Text="•" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="自定义" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="自填 URL" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                     Title="安全说明"
                     Message="所有凭据经 DPAPI 加密后仅存储在本地，不会上传任何服务器。自定义提供商强制 HTTPS。"/>
        </StackPanel>
    </ScrollViewer>
</Page>
