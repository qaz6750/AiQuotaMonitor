<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="28,18,28,40" Spacing="16">

            <StackPanel Spacing="3">
                <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="按 Coding Plan、Token Plan、API 按量付费分类管理多平台账号。所有凭据仅本地加密保存。" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
            </StackPanel>

            <!-- ===== 账号管理 ===== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="账号管理" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="已接入：GLM、Kimi、MiMo、MiniMax、Factory、GPT、Claude、OpenRouter、DeepSeek、Moonshot/Kimi API、ElevenLabs。Cookie 平台会提示并默认显示网页登录账户名。" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding StartAddCommand}" Padding="14,7" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="13"/>
                                <TextBlock Text="添加账号" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 编辑/新建表单 -->
                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource PageBackgroundBrush}"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding EditingHeader}" FontSize="14" FontWeight="SemiBold"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="账号名称（可选，用于区分多个账号）" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <TextBox Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="如：工作账号 / 个人 Pro"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="套餐类型" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <ComboBox SelectedIndex="{Binding EditingPlanIndex, Mode=TwoWay}" MinWidth="260">
                                    <x:String>Coding Plan</x:String>
                                    <x:String>Token Plan</x:String>
                                    <x:String>API 按量付费</x:String>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="提供商" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <ComboBox ItemsSource="{Binding ProviderOptions}"
                                          SelectedIndex="{Binding EditingProviderIndex, Mode=TwoWay}"
                                          MinWidth="320">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="10" MinWidth="260">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30" Height="30" CornerRadius="9" Background="{Binding BrandColor, Converter={StaticResource HexToBrush}}">
                                                    <TextBlock Text="{Binding Glyph}" Foreground="White" FontWeight="Bold" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding CredentialLabel}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                                    <Button Command="{Binding FetchCredentialCommand}" Content="一键获取" Padding="10,3" FontSize="11" Visibility="{Binding CanAutoFetchCredential, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <PasswordBox Password="{Binding EditingApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="按所选提供商填写 API Key、Admin Key、Subscription Key、Bearer Token 或 Cookie"/>
                                <TextBlock Text="{Binding CredentialHelpText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="4" Visibility="{Binding ShowBaseUrl, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="用量接口 / Base URL" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <TextBox Text="{Binding EditingBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="默认使用所选提供商的官方用量接口"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Command="{Binding SaveAccountCommand}" Style="{StaticResource AccentButtonStyle}" Padding="16,8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ProgressRing Width="14" Height="14" IsActive="{Binding IsTesting}" Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="保存" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CancelEditCommand}" Content="取消" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 账号列表 -->
                    <ItemsControl x:Name="AccountList" ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,10" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardBorderBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 提供商图标色块（叠加当前激活标记） -->
                                        <Grid Width="32" Height="32" VerticalAlignment="Center">
                                            <Border CornerRadius="9" Background="{Binding ProviderColor, Converter={StaticResource HexToBrush}}"/>
                                            <TextBlock Text="{Binding ProviderGlyph}" Foreground="White" FontWeight="Bold" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Ellipse Width="10" Height="10" Fill="#3FB950" Stroke="{ThemeResource CardBackgroundBrush}" StrokeThickness="1.5"
                                                     Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibility}}"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                <Border CornerRadius="4" Padding="6,1" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}">
                                                    <TextBlock Text="{Binding PlanBadge}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}">
                                                <Run Text="{Binding ProviderName}"/><Run Text=" · "/><Run Text="{Binding KeyHint}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.ActivateAccountCommand, ElementName=AccountList}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding IsCurrent, Converter={StaticResource InverseBoolToVisibility}}"
                                                    Background="Transparent" BorderThickness="0" Padding="10,5"
                                                    Content="设为当前" FontSize="11"/>
                                            <Button Command="{Binding DataContext.EditAccountCommand, ElementName=AccountList}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="10,5"
                                                    ToolTipService.ToolTip="编辑">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteAccountCommand, ElementName=AccountList}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="10,5"
                                                    ToolTipService.ToolTip="删除">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Visibility="{Binding HasAccounts, Converter={StaticResource InverseBoolToVisibility}}"
                               Text="还没有账号，点击右上角「添加账号」开始。" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>

                    <TextBlock Text="{Binding SaveMessage}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <!-- ===== 全局刷新偏好 ===== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="刷新与重试" FontSize="15" FontWeight="SemiBold"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="自动刷新间隔（分钟）" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <NumberBox Value="{Binding RefreshInterval, Mode=TwoWay}" Minimum="1" Maximum="1440" SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="5" Width="160" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <ToggleSwitch Header="启用自动刷新" IsOn="{Binding AutoRefresh, Mode=TwoWay}"/>
                    <ToggleSwitch Header="网络失败时自动重试" IsOn="{Binding EnableRetry, Mode=TwoWay}"/>
                    <ToggleSwitch Header="高用量警告提示" IsOn="{Binding WarnOnHighUsage, Mode=TwoWay}"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="高用量警告阈值（%）" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <NumberBox Value="{Binding WarnThreshold, Mode=TwoWay}" Minimum="1" Maximum="100" SpinButtonPlacementMode="Compact" Width="160" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="应用主题" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <ComboBox SelectedIndex="{Binding AppThemeIndex, Mode=TwoWay}" MinWidth="200">
                            <x:String>跟随系统</x:String>
                            <x:String>浅色</x:String>
                            <x:String>深色</x:String>
                        </ComboBox>
                    </StackPanel>

                    <Button Command="{Binding SavePreferencesCommand}" Content="保存偏好" Padding="16,8"/>
                </StackPanel>
            </Border>

            <!-- ===== 数据与关于 ===== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="数据与关于" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="所有账号凭据经 DPAPI（当前用户范围）加密后仅存储在本地，不会上传任何服务器。" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                    <Button Command="{Binding ResetAllCommand}" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                            <TextBlock Text="清理全部数据" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}">
                        <Run Text="AI Quota Monitor"/><Run Text="  v1.0"/><Run Text="  ·  多提供商 AI 配额监控"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
