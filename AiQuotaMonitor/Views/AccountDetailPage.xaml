<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.AccountDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AiQuotaMonitor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="28,18,28,28" Spacing="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="13"/>
                        <TextBlock Text="返回概览" FontSize="12"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing Width="16" Height="16" IsActive="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" VerticalAlignment="Center"/>
                    <Button Command="{Binding RefreshCommand}" Padding="14,7" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                            <TextBlock Text="刷新" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

<!-- ============ 服务总览卡片 ============ -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 5h 进度环 -->
                    <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <controls:QuotaRingControl
                            Percentage="{Binding FiveHourPct}"
                            RingBrush="{Binding FiveHourBrush}"
                            CenterLabel="{Binding RingCenterLabel}"
                            Diameter="104"
                            StrokeThickness="9"/>
                        <TextBlock Text="{Binding PrimaryQuotaLabel}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 右侧信息 -->
                    <StackPanel Grid.Column="1" Margin="30,0,0,0" Spacing="16" VerticalAlignment="Center">
                        <!-- 服务头 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="6" Padding="11,4">
                                    <TextBlock Text="{Binding LevelText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="{Binding ServiceName}" VerticalAlignment="Center" Foreground="{ThemeResource SecondaryTextBrush}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource SubtleTextBrush}" FontSize="12"
                                       Visibility="{Binding HasResetTime, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="下次重置"/><Run Text=" "/><Run Text="{Binding FiveHourResetText}"/>
                            </TextBlock>
                        </Grid>

                        <!-- 周额度 -->
                        <StackPanel Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SecondaryQuotaLabel}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WeeklyPctText}" FontWeight="SemiBold" Foreground="{Binding WeeklyBrush}"/>
                                    <TextBlock Text="{Binding WeeklyResetText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                                </StackPanel>
                            </Grid>
                            <controls:SlimProgressBar Value="{Binding WeeklyPct}" FillBrush="{Binding WeeklyBrush}" TrackHeight="6"/>
                            <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}">
                                <Run Text="{Binding WeeklyTokensText}"/><Run Text=" / "/><Run Text="{Binding WeeklyCapText}"/><Run Text=" tokens"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- 双列：花费 / 5h 预估 -->
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="等价 API 花费" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding CostText}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CostWindowLabel}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2" Visibility="{Binding FiveHourEstimateText, Converter={StaticResource StringToVisibility}}">
                                <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"><Run Text="{Binding PrimaryQuotaLabel}"/><Run Text=" 预估"/></TextBlock>
                                <TextBlock Text="{Binding FiveHourEstimateText}" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ KPI 行 ============ -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCard Label="今日 Tokens" Value="{Binding TodayTokensText}" SubLabel="所有模型合计"/>
                <controls:StatCard Grid.Column="1" Label="今日调用" Value="{Binding TodayCallsText}" SubLabel="次"/>
                <controls:StatCard Grid.Column="2" Label="活跃天数" Value="{Binding ActiveDaysText}" SubLabel="近 30 天"/>
            </Grid>

            <!-- ============ 今日用量 ============ -->
            <Border Style="{StaticResource CardStyle}" Visibility="{Binding HasTodayUsage, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="今日用量" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="悬停查看每小时用量" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </StackPanel>
                        <HyperlinkButton Grid.Column="1" Command="{Binding GoStatsCommand}" Padding="0" VerticalAlignment="Center">
                            <TextBlock Text="查看详细统计 →" FontSize="12"/>
                        </HyperlinkButton>
                    </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,0,2" Visibility="{Binding HasTrend, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="小时范围" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                        <NumberBox Value="{Binding HourStart, Mode=TwoWay}" Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="62"/>
                        <TextBlock Text="时至" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                        <NumberBox Value="{Binding HourEnd, Mode=TwoWay}" Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="62"/>
                        <Button Command="{Binding CalcHourRangeCommand}" Content="计算" Padding="12,5"/>
                        <TextBlock Text="{Binding HourRangeResult}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:UsageChartControl x:Name="TodayChart" Trend="{Binding TrendToday}" ShowAxis="True" Height="160"/>
                </StackPanel>
            </Border>

            <!-- ============ MCP 月度 ============ -->
            <Border Style="{StaticResource CardStyle}" Visibility="{Binding HasMcp, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MCP 月度用量" FontSize="15" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding McpPctText}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding McpResetText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </StackPanel>
                    </Grid>
                    <controls:SlimProgressBar Value="{Binding McpPct}" FillBrush="{Binding McpBrush}" TrackHeight="6"/>
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="已用" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                            <TextBlock Text="{Binding McpUsageText}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="总额度" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                            <TextBlock Text="{Binding McpTotalText}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="剩余" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                            <TextBlock Text="{Binding McpRemainingText}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
