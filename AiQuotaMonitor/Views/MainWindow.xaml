<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AiQuotaMonitor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{ThemeResource PageBackgroundColor}" Offset="0"/>
                <GradientStop Color="{ThemeResource SoftPanelBackgroundColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（半透明模糊背景，融入 Mica） -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="44" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="{ThemeResource TitleBarBrush}"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="10">
                <TextBlock Text="📊" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Text="AI Quota Monitor" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 自定义侧边栏 + 内容区（不再使用 NavigationView，避免文字丢失与底部留白） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 侧边栏 -->
            <Border Grid.Column="0" Background="{ThemeResource SidebarBackgroundBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 品牌块 -->
                    <StackPanel Grid.Row="0" Margin="18,16,18,8" Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="13">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#38BDF8" Offset="0"/>
                                        <GradientStop Color="#0EA5E9" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="AI" Foreground="White" FontWeight="Bold" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="AI Quota Monitor" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="配额 · Token · 费用" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Border CornerRadius="999" Padding="12,4" Background="{ThemeResource SoftPanelBackgroundBrush}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="#22C55E"/>
                                <TextBlock Text="本地加密 · 多平台监控" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 导航项 -->
                    <StackPanel Grid.Row="1" Margin="12,8,12,0" Spacing="4">
                        <RadioButton x:Name="NavOverview" GroupName="Nav" Tag="overview" Style="{StaticResource NavRadioButtonStyle}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE80F;" FontSize="15" Foreground="{ThemeResource SecondaryTextColor}"/>
                                <TextBlock Text="仪表盘" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavStats" GroupName="Nav" Tag="stats" Style="{StaticResource NavRadioButtonStyle}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE7C1;" FontSize="15" Foreground="{ThemeResource SecondaryTextColor}"/>
                                <TextBlock Text="用量统计" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- 底部设置 -->
                    <StackPanel Grid.Row="3" Margin="12,0,12,16" Spacing="10">
                        <Border Height="1" Background="{ThemeResource CardBorderBrush}" Opacity="0.6" Margin="2,0"/>
                        <RadioButton x:Name="NavSettings" GroupName="Nav" Tag="settings" Style="{StaticResource NavRadioButtonStyle}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE713;" FontSize="15" Foreground="{ThemeResource SecondaryTextColor}"/>
                                <TextBlock Text="设置" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Frame Grid.Column="1" x:Name="NavFrame" Background="Transparent" CacheSize="4">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition>
                            <NavigationThemeTransition.DefaultNavigationTransitionInfo>
                                <EntranceNavigationTransitionInfo/>
                            </NavigationThemeTransition.DefaultNavigationTransitionInfo>
                        </NavigationThemeTransition>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </Grid>
    </Grid>
</Window>
