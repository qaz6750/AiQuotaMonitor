<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AiQuotaMonitor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="28,14,28,28" Spacing="16">

            <!-- ============ Header ============ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="仪表盘" FontSize="22" FontWeight="SemiBold"/>
                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing Width="18" Height="18" IsActive="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Command="{Binding RefreshCommand}" Padding="14,7" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                            <TextBlock Text="刷新" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ 错误提示 ============ -->
            <InfoBar
                IsOpen="{Binding HasError}"
                Severity="Error"
                Title="刷新失败"
                Message="{Binding ErrorMessage}"
                IsClosable="False"/>

            <!-- ============ 未配置账号提示 ============ -->
            <InfoBar
                IsOpen="{Binding HasNoAccount}"
                Severity="Informational"
                Title="尚未配置账号"
                Message="添加一个 API Key 即可开始监控用量。"
                IsClosable="False">
                <InfoBar.ActionButton>
                    <Button Command="{Binding GoSettingsCommand}" Content="去设置" Padding="14,6"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- ============ API 按量付费说明 ============ -->
            <InfoBar
                IsOpen="{Binding IsPayAsYouGoPlan}"
                Severity="Informational"
                Title="API 按量付费"
                Message="当前账号按模型 token 用量估算等价 API 花费；配额窗口可能不适用，以统计页的模型明细和费用为准。"
                IsClosable="False"/>

            <!-- ============ 多账号概览：顶部合计 + 每账号一行 ============ -->
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="账号" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding AccountCount}" FontSize="28" FontWeight="SemiBold" Foreground="#22C55E"/>
                        <TextBlock Text="已保存账号" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Token" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding TotalTodayTokensText}" FontSize="28" FontWeight="SemiBold" Foreground="#C85CFF"/>
                        <TextBlock Text="今日合计" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="状态" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding StatusText}" FontSize="28" FontWeight="SemiBold"/>
                                <ProgressRing Width="16" Height="16" IsActive="{Binding IsLoadingAll}" Margin="8,0,0,5"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" HorizontalAlignment="Right">
                            <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Text="点击卡片查看详细" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource CardStyle}" Padding="18">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="14" Background="#152A24">
                            <FontIcon Glyph="&#xE9D2;" Foreground="#34D399" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="费用换算" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CostWindowLabel}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CostFormulaText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CostBreakdownText}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding CostText}" FontSize="30" FontWeight="SemiBold" Foreground="#34D399" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ 全部账号近 3 天用量（按账号堆叠） ============ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="仪表盘时段图" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="每个小方块代表一个时段，颜色越深用量越高；鼠标悬浮可查看 token、调用次数与各账号明细。" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="999" Padding="10,4" Background="{ThemeResource SoftPanelBackgroundBrush}" VerticalAlignment="Center">
                            <TextBlock Text="Hover 查看详情" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </Border>
                    </Grid>
                    <controls:UsageHeatmapControl Trend="{Binding CombinedTrend}"/>
                </StackPanel>
            </Border>

            <ItemsControl x:Name="SummaryList" ItemsSource="{Binding Summaries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenAccountCommand, ElementName=SummaryList}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource CardButtonStyle}"
                                Padding="16,12" Margin="0,0,0,10">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="12" Background="{Binding ProviderColor, Converter={StaticResource HexToBrush}}">
                                    <TextBlock Text="{Binding ProviderGlyph}" Foreground="White" FontWeight="Bold" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <Border CornerRadius="10" Padding="8,2" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}">
                                            <TextBlock Text="{Binding PlanBadge}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}">
                                        <Run Text="今日"/><Run Text=" "/><Run Text="{Binding TodayTokensText}"/><Run Text=" tokens"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CostHint}" FontSize="11" Foreground="#34D399"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding PrimaryDisplay}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="5h" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SecondaryDisplay}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="周" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <controls:SlimProgressBar Grid.Column="3" Value="{Binding FiveHourPct}" FillBrush="{Binding BarBrush}" TrackHeight="6" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

                    </StackPanel>
    </ScrollViewer>
</Page>
