<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AiQuotaMonitor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="24,10,24,22" Spacing="10">

            <!-- ============ Header ============ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="仪表盘" FontSize="22" FontWeight="SemiBold"/>
                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OverviewSubtitle}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing Width="18" Height="18" IsActive="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Command="{Binding RefreshCommand}" Padding="14,7" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                            <TextBlock Text="刷新" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ 错误提示 ============ -->
            <InfoBar
                IsOpen="{Binding HasError}"
                Severity="Error"
                Title="刷新失败"
                Message="{Binding ErrorMessage}"
                IsClosable="False"/>

            <!-- ============ 未配置账号提示 ============ -->
            <InfoBar
                IsOpen="{Binding HasNoAccount}"
                Severity="Informational"
                Title="尚未配置账号"
                Message="添加一个 API Key 即可开始监控用量。"
                IsClosable="False">
                <InfoBar.ActionButton>
                    <Button Command="{Binding GoSettingsCommand}" Content="去设置" Padding="14,6"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- ============ API 按量付费说明 ============ -->
            <InfoBar
                IsOpen="{Binding IsPayAsYouGoPlan}"
                Severity="Informational"
                Title="API 按量付费"
                Message="当前账号按模型 token 用量估算等价 API 花费；配额窗口可能不适用，以统计页的模型明细和费用为准。"
                IsClosable="False"/>

            <!-- ============ 多账号概览：紧凑总览 ============ -->
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" CornerRadius="21">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#38BDF8" Offset="0"/>
                                <GradientStop Color="#0EA5E9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <FontIcon Glyph="&#xE9D9;" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="今日总览" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProviderInsightText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                            <ProgressRing Width="14" Height="14" IsActive="{Binding IsLoadingAll}" Visibility="{Binding IsLoadingAll, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource MetricPillStyle}">
                                <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"><Run Text="账号 "/><Run Text="{Binding AccountCount}"/></TextBlock>
                            </Border>
                            <Border Style="{StaticResource MetricPillStyle}">
                                <TextBlock FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"><Run Text="Token "/><Run Text="{Binding TotalTodayTokensText}"/></TextBlock>
                            </Border>
                            <TextBlock Text="{Binding CostBreakdownText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="360" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                        <TextBlock Text="{Binding CostText}" FontSize="28" FontWeight="SemiBold" Foreground="#34D399" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding CostWindowLabel}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="16" Visibility="{Binding HasCombinedTrend, Converter={StaticResource InverseBoolToVisibility}}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="17" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
                        <FontIcon Glyph="&#xE946;" FontSize="15" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="暂无可绘制趋势" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="余额类或 Cookie 类提供商可能只返回当前额度，不提供小时趋势；账号卡片仍会展示可用配额。" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ 全部账号近 3 天用量（按账号堆叠） ============ -->
            <Border Style="{StaticResource CardStyle}" Padding="16" Visibility="{Binding HasCombinedTrend, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="仪表盘时段图" FontSize="15" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Style="{StaticResource MetricPillStyle}">
                                    <TextBlock Text="{Binding TopModelText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="320" VerticalAlignment="Center"/>
                                </Border>
                                <Border Style="{StaticResource MetricPillStyle}">
                                    <TextBlock Text="{Binding PeakUsageText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="240" VerticalAlignment="Center"/>
                                </Border>
                                <Border Style="{StaticResource MetricPillStyle}">
                                    <TextBlock Text="{Binding ToolInsightText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="260" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource MetricPillStyle}" VerticalAlignment="Center">
                            <TextBlock Text="悬停查看每小时明细" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </Border>
                    </Grid>
                    <controls:UsageHeatmapControl Trend="{Binding CombinedTrend}"/>
                </StackPanel>
            </Border>

            <ItemsControl x:Name="SummaryList" ItemsSource="{Binding Summaries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenAccountCommand, ElementName=SummaryList}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource CardButtonStyle}"
                                Padding="14,10" Margin="0,0,0,8">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="14" Background="{Binding ProviderColor, Converter={StaticResource HexToBrush}}">
                                    <Grid>
                                        <Image Width="23" Height="23" Stretch="Uniform"
                                               Source="{Binding ProviderLogoPath, Converter={StaticResource LogoPathToImageSource}}"
                                               Visibility="{Binding ProviderLogoPath, Converter={StaticResource StringToVisibility}}"/>
                                        <TextBlock Text="{Binding ProviderLogoText}" Foreground="White" FontWeight="Bold" FontSize="{Binding ProviderLogoFontSize}"
                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding ProviderLogoPath, Converter={StaticResource InverseStringToVisibility}}"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <Border CornerRadius="10" Padding="8,2" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}">
                                            <TextBlock Text="{Binding PlanBadge}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding UsageDensityText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding PrimaryDisplay}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding PrimaryLabel}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SecondaryDisplay}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding SecondaryLabel}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <controls:SlimProgressBar Grid.Column="3" Value="{Binding FiveHourPct}" FillBrush="{Binding BarBrush}" TrackHeight="6" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

                    </StackPanel>
    </ScrollViewer>
</Page>
