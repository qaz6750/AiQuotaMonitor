<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <Grid Padding="24,12,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="日志" FontSize="22" FontWeight="SemiBold"/>
                    <Border CornerRadius="14" Padding="12,4" Height="28" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
                        <TextBlock Text="本地日志" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="查看刷新、提供商请求和异常日志。敏感凭据不会写入日志。" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Click="Refresh_Click" Style="{StaticResource AccentButtonStyle}" Padding="14,7">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                        <TextBlock Text="刷新" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Click="Clear_Click" Padding="14,7" Background="Transparent" BorderBrush="{ThemeResource CardBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                        <TextBlock Text="清空" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="搜索 provider、错误、账号 ID 或 HTTP 状态" TextChanged="Search_TextChanged"/>
                <Border Grid.Column="1" Style="{StaticResource MetricPillStyle}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding LogPathText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
            <ListView ItemsSource="{Binding FilteredEntries}" SelectionMode="None" Background="Transparent" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="14,9" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Time}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" FontFamily="Consolas"/>
                            <Border Grid.Column="1" CornerRadius="8" Padding="7,2" Background="{Binding LevelColor, Converter={StaticResource HexToBrush}}" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Level}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="{Binding HasNoLogs, Converter={StaticResource BoolToVisibility}}">
                    <FontIcon Glyph="&#xF000;" FontSize="26" Foreground="{ThemeResource SubtleTextBrush}"/>
                    <TextBlock Text="暂无日志" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="刷新账号或发生错误后会在这里显示。" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
