<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.ProvidersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="24,12,24,32" Spacing="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Providers" FontSize="22" FontWeight="SemiBold"/>
                        <Border CornerRadius="999" Padding="9,3" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
                            <TextBlock Text="Quotio-style catalog" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="按提供商聚合账号、能力和接入状态。这里用于总览，新增或编辑凭据仍在设置页完成。" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Click="AddAccount_Click" Style="{StaticResource AccentButtonStyle}" Padding="14,7" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="13"/>
                        <TextBlock Text="添加账号" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="已接入" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding ConnectedText}" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="可用提供商" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding ProviderCountText}" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="当前策略" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}"/>
                        <TextBlock Text="本地加密" FontSize="28" FontWeight="SemiBold" Foreground="#22C55E"/>
                    </StackPanel>
                </Border>
            </Grid>

            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="16,0,0,16" Background="{Binding BrandColor, Converter={StaticResource HexToBrush}}"/>
                                <Grid Grid.Column="1" Padding="16" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="46" Height="46" CornerRadius="16" Background="{Binding BrandColor, Converter={StaticResource HexToBrush}}">
                                        <Grid>
                                            <Image Width="25" Height="25" Stretch="Uniform" Source="{Binding LogoPath, Converter={StaticResource LogoPathToImageSource}}" Visibility="{Binding LogoPath, Converter={StaticResource StringToVisibility}}"/>
                                            <TextBlock Text="{Binding LogoText}" Foreground="White" FontWeight="Bold" FontSize="{Binding LogoFontSize}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding LogoPath, Converter={StaticResource InverseStringToVisibility}}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                            <Border CornerRadius="9" Padding="8,2" Background="{ThemeResource SoftPanelBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
                                                <TextBlock Text="{Binding PlanText}" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}"/>
                                            </Border>
                                            <Border CornerRadius="9" Padding="8,2" Background="{Binding StatusBrush, Converter={StaticResource HexToBrush}}" Opacity="0.95">
                                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CapabilityText}" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <StackPanel Spacing="2" MinWidth="72">
                                            <TextBlock Text="{Binding AccountCount}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="账号" FontSize="10" Foreground="{ThemeResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Click="ProviderAdd_Click" Tag="{Binding Id}" Padding="12,6" Background="Transparent" BorderBrush="{ThemeResource CardBorderBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE710;" FontSize="11"/>
                                                <TextBlock Text="接入" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
