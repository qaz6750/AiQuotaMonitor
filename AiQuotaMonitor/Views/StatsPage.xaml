<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiQuotaMonitor.Views.StatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AiQuotaMonitor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <ScrollViewer Padding="0">
        <StackPanel Padding="28,18,28,28" Spacing="16">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="12"/>
                    <ContentThemeTransition HorizontalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <TextBlock Text="用量统计" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatsInsightText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Padding="14,7">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                            <TextBlock Text="刷新" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GoOverviewCommand}" Padding="14,7" Style="{StaticResource AccentButtonStyle}">
                        <TextBlock Text="返回概览" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 时间范围 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="时间范围" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="悬停柱体查看该时段用量" FontSize="11" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="7" Padding="2"
                        Background="{ThemeResource CardBackgroundBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <RadioButton x:Name="RangeToday" GroupName="StatsRange" Content="今日" Tag="0" Checked="Range_Checked" Padding="14,5" MinWidth="0"/>
                        <RadioButton x:Name="Range7d" GroupName="StatsRange" Content="近 7 天" Tag="1" Checked="Range_Checked" Padding="14,5" MinWidth="0"/>
                        <RadioButton x:Name="Range30d" GroupName="StatsRange" Content="近 30 天" Tag="2" Checked="Range_Checked" Padding="14,5" MinWidth="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- KPI -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCard Label="Token 总量" Value="{Binding TokensText}" SubLabel="{Binding RangeLabel}"/>
                <controls:StatCard Grid.Column="1" Label="调用次数" Value="{Binding CallsText}" SubLabel="{Binding RangeLabel}"/>
                <controls:StatCard Grid.Column="2" Label="等价 API 花费" Value="{Binding CostText}" SubLabel="按量计费参考价"/>
                <controls:StatCard Grid.Column="3" Label="Top 模型" Value="{Binding TopModelText}" SubLabel="按 token 排序"/>
                <controls:StatCard Grid.Column="4" Label="峰值" Value="{Binding PeakText}" SubLabel="最高时段"/>
            </Grid>

            <!-- 趋势图 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="按模型用量趋势" FontSize="15" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,0,2">
                        <TextBlock Text="范围" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                        <DatePicker Date="{Binding RangeStart, Mode=TwoWay}" YearVisible="False" DayVisible="True" MonthVisible="True" Width="150"/>
                        <NumberBox Value="{Binding HourStart, Mode=TwoWay}" Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="56" Visibility="{Binding IsHourly, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="至" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                        <DatePicker Date="{Binding RangeEnd, Mode=TwoWay}" YearVisible="False" DayVisible="True" MonthVisible="True" Width="150"/>
                        <NumberBox Value="{Binding HourEnd, Mode=TwoWay}" Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="56" Visibility="{Binding IsHourly, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Command="{Binding CalcRangeCommand}" Content="计算" Padding="12,5"/>
                        <TextBlock Text="{Binding RangeResult}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:UsageChartControl x:Name="StatsChart" Trend="{Binding Trend}" ShowAxis="True" Height="220"/>
                </StackPanel>
            </Border>

            <!-- 按模型明细 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="按模型明细" FontSize="15" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Breakdown}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5" Spacing="4">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="{Binding Color, Converter={StaticResource HexToBrush}}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Model}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PercentText}" FontSize="12" Foreground="{ThemeResource SubtleTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding TokensText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                    </Grid>
                                    <controls:SlimProgressBar Value="{Binding Percent}" FillBrush="{Binding Color, Converter={StaticResource HexToBrush}}" TrackHeight="4" Margin="20,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
