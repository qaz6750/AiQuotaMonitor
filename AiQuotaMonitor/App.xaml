<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AiQuotaMonitor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:AiQuotaMonitor.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 全局主题色资源：随系统暗色模式自动切换 -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="PageBackgroundColor">#F4F7FB</Color>
                    <Color x:Key="CardBackgroundColor">#FDFEFF</Color>
                    <Color x:Key="CardBorderColor">#DDE5F0</Color>
                    <Color x:Key="SubtleTextColor">#6B7280</Color>
                    <Color x:Key="SecondaryTextColor">#243044</Color>
                    <Color x:Key="CardStrokeColor">#00000000</Color>
                    <Color x:Key="TitleBarBackgroundColor">#EEF4FB</Color>
                    <Color x:Key="SidebarBackgroundColor">#F7F9FC</Color>
                    <Color x:Key="SoftPanelBackgroundColor">#EEF3F8</Color>
                    <Color x:Key="NavSelectedBackgroundColor">#E7F1FF</Color>
                    <Color x:Key="GlowColor">#3358F5B8</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="PageBackgroundColor">#111315</Color>
                    <Color x:Key="CardBackgroundColor">#202123</Color>
                    <Color x:Key="CardBorderColor">#32343A</Color>
                    <Color x:Key="SubtleTextColor">#9AA0AA</Color>
                    <Color x:Key="SecondaryTextColor">#E4E7EC</Color>
                    <Color x:Key="CardStrokeColor">#00000000</Color>
                    <Color x:Key="TitleBarBackgroundColor">#111315</Color>
                    <Color x:Key="SidebarBackgroundColor">#121417</Color>
                    <Color x:Key="SoftPanelBackgroundColor">#1B1D22</Color>
                    <Color x:Key="NavSelectedBackgroundColor">#1C2A3A</Color>
                    <Color x:Key="GlowColor">#663B82F6</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- 更柔和的强调蓝（覆盖系统默认深蓝，明暗通用）。内容项须统一位于属性元素之后。 -->
            <Color x:Key="SystemAccentColor">#0EA5E9</Color>
            <Color x:Key="SystemAccentColorLight1">#38BDF8</Color>
            <Color x:Key="SystemAccentColorLight2">#7DD3FC</Color>
            <Color x:Key="SystemAccentColorLight3">#BAE6FD</Color>
            <Color x:Key="SystemAccentColorDark1">#0284C7</Color>
            <Color x:Key="SystemAccentColorDark2">#0369A1</Color>
            <Color x:Key="SystemAccentColorDark3">#075985</Color>

            <SolidColorBrush x:Key="PageBackgroundBrush" Color="{ThemeResource PageBackgroundColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource CardBackgroundColor}" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="{ThemeResource CardBorderColor}" />
            <SolidColorBrush x:Key="SubtleTextBrush" Color="{ThemeResource SubtleTextColor}" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{ThemeResource SecondaryTextColor}" />
            <SolidColorBrush x:Key="TitleBarBrush" Color="{ThemeResource TitleBarBackgroundColor}" Opacity="0.35" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{ThemeResource SidebarBackgroundColor}" Opacity="0.92" />
            <SolidColorBrush x:Key="NavSelectedBackgroundBrush" Color="{ThemeResource NavSelectedBackgroundColor}" />
            <SolidColorBrush x:Key="SoftPanelBackgroundBrush" Color="{ThemeResource SoftPanelBackgroundColor}" />
            <SolidColorBrush x:Key="CardHoverBrush" Color="{ThemeResource NavSelectedBackgroundColor}" Opacity="0.45" />

            <!-- 配额颜色（固定，明暗通用） -->
            <Color x:Key="QuotaGoodColor">#3FB950</Color>
            <Color x:Key="QuotaWarnColor">#E0A800</Color>
            <Color x:Key="QuotaDangerColor">#F0883E</Color>
            <SolidColorBrush x:Key="QuotaGoodBrush" Color="{ThemeResource QuotaGoodColor}" />
            <SolidColorBrush x:Key="QuotaWarnBrush" Color="{ThemeResource QuotaWarnColor}" />
            <SolidColorBrush x:Key="QuotaDangerBrush" Color="{ThemeResource QuotaDangerColor}" />

            <!-- 圆角卡片样式 -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="CardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="TitleText" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="FontSize" Value="18" />
            </Style>

            <Style x:Key="BigNumberText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="34" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>

            <Style x:Key="MetricPillStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="9,3" />
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="#220EA5E9" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <!-- 全局值转换器 -->
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:NotNullToVisibilityConverter x:Key="NotNullToVisibility"/>
            <helpers:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <helpers:HexToBrushConverter x:Key="HexToBrush"/>
            <helpers:HexToSoftBrushConverter x:Key="HexToSoftBrush"/>

            <!-- 侧边栏导航项样式：透明常态 / 悬浮软背景 / 选中态强调色背景 + 左侧高亮条 -->
            <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Root"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SoftPanelBackgroundBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SoftPanelBackgroundBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Checked">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource NavSelectedBackgroundBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#550EA5E9"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked"/>
                                        <VisualState x:Name="Indeterminate"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
