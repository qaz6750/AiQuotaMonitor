<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AiQuotaMonitor.Controls.SlimProgressBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <!-- 细进度条（参考 cc-bar 5pt weekly bar / HUD 4pt bar） -->
    <Grid x:Name="Root">
        <Border Background="{ThemeResource CardBorderBrush}" CornerRadius="2.5"/>
        <Border x:Name="Fill" HorizontalAlignment="Left" CornerRadius="2.5"/>
    </Grid>
</UserControl>
